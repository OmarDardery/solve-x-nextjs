generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ApplicantType {
  STUDENT
  PROFESSOR
}

model Student {
  id                  BigInt         @id @default(autoincrement())
  createdAt           DateTime?      @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?      @map("deleted_at") @db.Timestamptz(6)
  firstName           String?        @map("first_name")
  lastName            String?        @map("last_name")
  email               String?        @unique(map: "uni_students_email")
  password            String?
  lastChangedPassword DateTime?      @map("last_changed_password") @db.Timestamptz(6)
  applications        Application[]
  opportunities       Opportunity[]
  coins               Coins?
  student_tags        StudentTags[]
  reports             WeeklyReport[]

  @@index([deletedAt], map: "idx_students_deleted_at")
  @@map("students")
}

model Professor {
  id                  BigInt         @id @default(autoincrement())
  createdAt           DateTime?      @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?      @map("deleted_at") @db.Timestamptz(6)
  firstName           String?        @map("first_name")
  lastName            String?        @map("last_name")
  email               String?        @unique(map: "uni_professors_email")
  password            String?
  lastChangedPassword DateTime?      @map("last_changed_password") @db.Timestamptz(6)
  opportunities       Opportunity[]
  submittedApplications Application[]
  receivedReports     WeeklyReport[] @relation("ReportRecipient")

  @@index([deletedAt], map: "idx_professors_deleted_at")
  @@map("professors")
}

model Organization {
  id                  BigInt    @id @default(autoincrement())
  createdAt           DateTime? @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)
  name                String?
  email               String?   @unique(map: "uni_organizations_email")
  password            String?
  contact             String?
  link                String?
  lastChangedPassword DateTime? @map("last_changed_password") @db.Timestamptz(6)
  events              Event[]

  @@index([deletedAt], map: "idx_organizations_deleted_at")
  @@map("organizations")
}

model Tag {
  id               BigInt            @id @default(autoincrement())
  createdAt        DateTime?         @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime?         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz(6)
  name             String            @unique(map: "uni_tags_name")
  description      String?
  opportunity_tags OpportunityTags[]
  student_tags     StudentTags[]

  @@index([deletedAt], map: "idx_tags_deleted_at")
  @@map("tags")
}

model Coins {
  id        BigInt    @id @default(autoincrement())
  createdAt DateTime? @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  amount    BigInt
  studentId BigInt    @unique(map: "idx_coins_student_id") @map("student_id")
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "fk_students_coins")

  @@index([deletedAt], map: "idx_coins_deleted_at")
  @@map("coins")
}

model Opportunity {
  id               BigInt            @id @default(autoincrement())
  createdAt        DateTime?         @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime?         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz(6)
  professorId      BigInt?           @map("professor_id")
  studentId        BigInt?           @map("student_id")
  name             String
  details          String?
  requirements     String?
  reward           String?
  type             String
  applications     Application[]
  professor        Professor?        @relation(fields: [professorId], references: [id], onDelete: Cascade, map: "fk_opportunities_professor")
  student          Student?          @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "fk_opportunities_student")
  opportunity_tags OpportunityTags[]

  @@index([deletedAt], map: "idx_opportunities_deleted_at")
  @@map("opportunities")
}

model Application {
  id            BigInt      @id @default(autoincrement())
  createdAt     DateTime?   @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?   @map("deleted_at") @db.Timestamptz(6)
  studentId     BigInt?     @map("student_id")
  professorApplicantId BigInt? @map("professor_id")
  opportunityId BigInt      @map("opportunity_id")
  message       String?
  resumeLink    String?     @map("resume_link")
  status        String      @default("pending")
  applicantType String @map("applicant_type") @default("STUDENT")
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade, map: "fk_applications_opportunity")
  student       Student?    @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "fk_applications_student")
  professorApplicant Professor? @relation(fields: [professorApplicantId], references: [id], onDelete: Cascade, map: "fk_applications_professor_applicant")

  @@index([deletedAt], map: "idx_applications_deleted_at")
  @@map("applications")
}

model Event {
  id             BigInt        @id @default(autoincrement())
  createdAt      DateTime?     @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime?     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamptz(6)
  title          String?
  description    String?
  date           String?
  link           String?
  signUpLink     String?       @map("sign_up_link")
  organizationId BigInt?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_events_organization")

  @@index([deletedAt], map: "idx_events_deleted_at")
  @@map("events")
}

model WeeklyReport {
  id          BigInt    @id @default(autoincrement())
  createdAt   DateTime? @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  studentId   BigInt    @map("student_id")
  recipientId BigInt    @map("recipient_id")
  driveLink   String    @map("drive_link")
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "fk_weekly_reports_student")
  recipient   Professor @relation("ReportRecipient", fields: [recipientId], references: [id], onDelete: Cascade, map: "fk_weekly_reports_recipient")

  @@index([deletedAt], map: "idx_weekly_reports_deleted_at")
  @@map("weekly_reports")
}

model Notification {
  id            BigInt    @id @default(autoincrement())
  createdAt     DateTime? @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  recipientId   BigInt    @map("recipient_id")
  recipientRole String    @map("recipient_role")
  title         String
  message       String
  type          String?   @default("info")
  read          Boolean?  @default(false)
  readAt        DateTime? @map("read_at") @db.Timestamptz(6)

  @@index([deletedAt], map: "idx_notifications_deleted_at")
  @@map("notifications")
}

model StudentTags {
  studentId BigInt  @map("student_id")
  tagId     BigInt  @map("tag_id")
  students  Student @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "fk_student_tags_student")
  tags      Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade, map: "fk_student_tags_tag")

  @@id([studentId, tagId])
  @@map("student_tags")
}

model OpportunityTags {
  opportunityId BigInt      @map("opportunity_id")
  tagId         BigInt      @map("tag_id")
  opportunities Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade, map: "fk_opportunity_tags_opportunity")
  tags          Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade, map: "fk_opportunity_tags_tag")

  @@id([opportunityId, tagId])
  @@map("opportunity_tags")
}
